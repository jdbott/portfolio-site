---
import Monogram from './Monogram.astro';
import { sortedAreas } from '../data/areas';

interface Props {
  alwaysVisible?: boolean;
}

const { alwaysVisible = false } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header id="site-nav" class:list={['nav', { 'always-visible': alwaysVisible }]}>
  <div class="nav__inner">
    <a href="/" class="nav__brand" aria-label="Home">
      <Monogram size={32} />
    </a>

    <nav class="nav__links" aria-label="Primary">
      <a href="/" class:list={['nav__link', { 'is-active': path === '/' }]}>Home</a>
      {sortedAreas.map((area) => (
        <a
          href={`/${area.slug}/`}
          class:list={['nav__link', { 'is-active': path === `/${area.slug}` }]}
        >
          {area.navLabel}
        </a>
      ))}
    </nav>

    <button class="nav__toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="nav__overlay" id="nav-overlay">
    <nav aria-label="Primary mobile">
      <a href="/" class:list={['nav__overlay-link', { 'is-active': path === '/' }]}>Home</a>
      {sortedAreas.map((area) => (
        <a
          href={`/${area.slug}/`}
          class:list={['nav__overlay-link', { 'is-active': path === `/${area.slug}` }]}
        >
          {area.navLabel}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const navEl = document.getElementById('site-nav');
  const toggle = document.getElementById('nav-toggle');
  const overlay = document.getElementById('nav-overlay');

  // Reveal the nav bar once the user scrolls past the first viewport.
  let ticking = false;
  const updateNav = () => {
    if (!navEl) return;
    const past = window.scrollY > window.innerHeight * 0.6;
    navEl.classList.toggle('is-visible', past);
    ticking = false;
  };

  window.addEventListener('scroll', () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(updateNav);
  });
  updateNav();

  // Mobile overlay menu
  toggle?.addEventListener('click', () => {
    const isOpen = navEl?.classList.toggle('menu-open');
    toggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });

  overlay?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      navEl?.classList.remove('menu-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // The dropdown no longer covers the full screen, so the page content
  // below it stays visible and tappable — clicking anywhere outside the
  // dropdown (and outside the toggle itself) should close it.
  document.addEventListener('click', (e) => {
    if (!navEl?.classList.contains('menu-open')) return;
    const target = e.target as Node;
    if (overlay?.contains(target) || toggle?.contains(target)) return;
    navEl.classList.remove('menu-open');
    toggle?.setAttribute('aria-expanded', 'false');
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: rgba(7, 7, 10, 0);
    backdrop-filter: blur(0px);
    border-bottom: 1px solid transparent;
    opacity: 0.45;
    transition:
      opacity var(--duration-base) var(--ease-out-expo),
      background-color var(--duration-base) var(--ease-out-expo),
      backdrop-filter var(--duration-base) var(--ease-out-expo),
      border-color var(--duration-base) var(--ease-out-expo);
  }

  /* Full view: scrolled past the hero, hovered, or on an area page */
  .nav.is-visible,
  .nav.always-visible,
  .nav:hover,
  .nav.menu-open {
    opacity: 1;
    background-color: rgba(7, 7, 10, 0.72);
    backdrop-filter: blur(12px);
    border-bottom-color: var(--color-border);
  }

  .nav__inner {
    position: relative;
    z-index: 2;
    max-width: var(--content-max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) var(--space-lg);
  }

  .nav__brand {
    display: flex;
    align-items: center;
  }

  .nav__links {
    display: none;
    align-items: center;
    gap: var(--space-lg);
  }

  .nav__link {
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
    position: relative;
    padding: var(--space-3xs) 0;
  }

  .nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 100%;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-fast) var(--ease-out-expo);
  }

  .nav__link:hover {
    color: var(--color-text);
  }

  .nav__link.is-active {
    color: var(--color-text);
  }

  .nav__link.is-active::after {
    transform: scaleX(1);
  }

  /* ---- Mobile toggle ---- */
  .nav__toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .nav__toggle span {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--color-text);
    transition: transform var(--duration-fast) var(--ease-out-expo), opacity var(--duration-fast) var(--ease-out-expo);
  }

  .nav.menu-open .nav__toggle span:first-child {
    transform: translateY(3.25px) rotate(45deg);
  }

  .nav.menu-open .nav__toggle span:last-child {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  /* ---- Mobile dropdown ----
     Anchored to the bottom edge of the nav bar (top: 100% of the fixed
     .nav ancestor) rather than covering the full screen, so it reads as
     a true dropdown — about half the viewport tall, with the rest of the
     page still visible (and tappable, see click-outside-to-close below)
     underneath it. */
  .nav__overlay {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 50vh;
    z-index: 1;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    justify-content: center;
    overflow-y: auto;
    padding: var(--space-lg) 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--duration-base) var(--ease-out-expo);
  }

  /* Vertical centering via auto margins instead of align-items: center —
     align-items centers an overflowing item by pushing the "before center"
     half out of scrollable reach entirely (a well-known flexbox gotcha).
     margin: auto still centers when there's extra space, but collapses to
     0 and joins the normal scrollable flow once content overflows, so
     every link stays reachable even within the shorter dropdown height. */
  .nav__overlay nav {
    margin: auto 0;
  }

  .nav.menu-open .nav__overlay {
    opacity: 1;
    visibility: visible;
  }

  .nav__overlay nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .nav__overlay-link {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-xl);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .nav__overlay-link:hover,
  .nav__overlay-link.is-active {
    color: var(--color-accent-strong);
  }

  @media (min-width: 720px) {
    .nav__links {
      display: flex;
    }

    .nav__toggle {
      display: none;
    }

    .nav__overlay {
      display: none;
    }
  }
</style>
