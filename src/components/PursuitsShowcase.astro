---
import type { Pursuit } from '../data/areas';
import { Image } from 'astro:assets';
import photographyImg from '../assets/pursuits/photography.jpg';
import photography2Img from '../assets/pursuits/photography2.jpg';
import photography3Img from '../assets/pursuits/photography3.jpg';
import bonsaiImg from '../assets/pursuits/bonsai.jpg';
import trackImg from '../assets/track.jpeg';
import fitnessImg from '../assets/fitness.jpeg';

interface Props {
  pursuits: Pursuit[];
}

const { pursuits } = Astro.props;

const mediaByTitle = {
  Photography: {
    images: [photographyImg, photography2Img, photography3Img],
    aspect: photographyImg.width / photographyImg.height,
  },
  Bonsai: {
    images: [bonsaiImg],
    aspect: bonsaiImg.width / bonsaiImg.height,
  },
  'Track & Field': {
    images: [trackImg],
    aspect: trackImg.width / trackImg.height,
  },
  Fitness: {
    images: [fitnessImg],
    aspect: fitnessImg.width / fitnessImg.height,
  },
} as const;
---

<section class="pursuits-showcase" aria-label="Personal pursuits">
  <div class="pursuits-showcase__inner">
    {pursuits.map((pursuit, index) => {
      const media = mediaByTitle[pursuit.title as keyof typeof mediaByTitle];

      return (
      <article class="pursuit scroll-reveal" style={`--index: ${index}`}>
        <div
          class:list={['pursuit__visual', { 'pursuit__visual--media': media, 'pursuit__visual--fitness': pursuit.title === 'Fitness' }]}
          style={media ? `--media-aspect: ${media.aspect}` : undefined}
          aria-label={media ? `${pursuit.title} image` : `${pursuit.title} image placeholder`}
          data-photo-carousel={media?.images.length && media.images.length > 1 ? true : undefined}
        >
          {media?.images.map((image, imageIndex) => (
            <Image
              class={`pursuit__image${imageIndex === 0 ? ' is-active' : ''}`}
              src={image}
              alt=""
              widths={[480, 720, 960, 1280, 1600, 2200]}
              sizes="(max-width: 820px) calc(100vw - 5rem), 55vw"
              quality={90}
              loading={index === 0 ? 'eager' : 'lazy'}
              fetchpriority={index === 0 ? 'high' : 'auto'}
            />
          ))}
          <span class="pursuit__number">{String(index + 1).padStart(2, '0')}</span>
          {media ? (
            media.images.length > 1 && (
              <div class="pursuit__progress" aria-hidden="true">
                {media.images.map((_, imageIndex) => (
                  <span class:list={{ 'is-active': imageIndex === 0 }}></span>
                ))}
              </div>
            )
          ) : (
            <div class="pursuit__placeholder">
              <span>Image forthcoming</span>
              <code>{pursuit.imagePath}</code>
            </div>
          )}
        </div>

        <div class="pursuit__content">
          <p class="pursuit__kicker">{pursuit.kicker}</p>
          <h2 class="pursuit__title">{pursuit.title}</h2>
          <p class="pursuit__description">{pursuit.description}</p>
          {pursuit.details.length > 0 && (
            <ul class="pursuit__details" aria-label={`${pursuit.title} details`}>
              {pursuit.details.map((detail) => <li>{detail}</li>)}
            </ul>
          )}
        </div>
      </article>
      );
    })}
  </div>
</section>

<script>
  // Adjust this single value to change the photography rotation speed.
  const PHOTO_INTERVAL_MS = 3500;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLElement>('[data-photo-carousel]').forEach((carousel) => {
    const images = Array.from(carousel.querySelectorAll<HTMLElement>('.pursuit__image'));
    const indicators = Array.from(carousel.querySelectorAll<HTMLElement>('.pursuit__progress span'));
    if (images.length < 2 || reduceMotion) return;

    let activeIndex = 0;
    setInterval(() => {
      images[activeIndex]?.classList.remove('is-active');
      indicators[activeIndex]?.classList.remove('is-active');
      activeIndex = (activeIndex + 1) % images.length;
      images[activeIndex]?.classList.add('is-active');
      indicators[activeIndex]?.classList.add('is-active');
    }, PHOTO_INTERVAL_MS);
  });
</script>

<style>
  .pursuits-showcase {
    padding: var(--space-lg) var(--space-lg) var(--space-3xl);
  }

  .pursuits-showcase__inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .pursuit {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    align-items: center;
    gap: clamp(2.5rem, 7vw, 7rem);
    min-height: min(68vh, 680px);
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--color-border);
  }

  .pursuit:nth-child(even) .pursuit__visual {
    order: 2;
  }

  .pursuit__visual {
    position: relative;
    min-height: clamp(320px, 42vw, 520px);
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at calc(20% + var(--index) * 18%) 30%, rgba(226, 51, 77, 0.22), transparent 38%),
      linear-gradient(145deg, var(--color-bg-overlay), var(--color-bg-raised));
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.22);
  }

  .pursuit__visual--media {
    min-height: 0;
    aspect-ratio: var(--media-aspect);
  }

  .pursuit__visual--fitness {
    width: min(100%, 360px);
    justify-self: center;
  }

  .pursuit__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transform: scale(1.015);
    transition:
      opacity 380ms var(--ease-out-expo),
      transform 900ms var(--ease-out-expo);
  }

  .pursuit__image.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .pursuit__visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 25%, rgba(255, 255, 255, 0.04) 50%, transparent 75%);
    transform: translateX(-100%);
    animation: pursuit-shimmer 8s ease-in-out infinite;
    animation-delay: calc(var(--index) * -1.4s);
    z-index: 2;
    pointer-events: none;
  }

  @keyframes pursuit-shimmer {
    0%, 65% { transform: translateX(-100%); }
    90%, 100% { transform: translateX(100%); }
  }

  .pursuit__number {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 800;
    line-height: 1;
    color: rgba(244, 243, 241, 0.06);
    z-index: 3;
  }

  .pursuit__placeholder {
    position: absolute;
    inset: auto var(--space-lg) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    color: var(--color-text-faint);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .pursuit__progress {
    position: absolute;
    right: var(--space-md);
    bottom: var(--space-md);
    z-index: 3;
    display: flex;
    gap: var(--space-2xs);
  }

  .pursuit__progress span {
    width: 26px;
    height: 2px;
    background: rgba(255, 255, 255, 0.35);
    transition: background-color var(--duration-fast) ease;
  }

  .pursuit__progress span.is-active {
    background: var(--color-accent-strong);
  }

  .pursuit__placeholder code {
    color: var(--color-text-muted);
    font-size: var(--fs-2xs);
    letter-spacing: 0;
    text-transform: none;
    overflow-wrap: anywhere;
  }

  .pursuit__kicker {
    margin-bottom: var(--space-sm);
    color: var(--color-gold);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .pursuit__title {
    margin-bottom: var(--space-md);
    font-size: clamp(2rem, 5vw, var(--fs-2xl));
  }

  .pursuit__description {
    color: var(--color-text-muted);
    font-size: var(--fs-sm);
    line-height: 1.75;
  }

  .pursuit__details {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    list-style: none;
    margin: var(--space-md) 0 0;
    padding: 0;
  }

  .pursuit__details li {
    padding: var(--space-3xs) var(--space-xs);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    font-size: var(--fs-xs);
  }

  @media (max-width: 820px) {
    .pursuit {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
      min-height: 0;
      padding: var(--space-2xl) 0;
    }

    .pursuit:nth-child(even) .pursuit__visual {
      order: initial;
    }

    .pursuit__visual {
      min-height: min(72vw, 440px);
    }

    .pursuit__visual--media {
      min-height: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pursuit__visual::after {
      animation: none;
    }
  }
</style>
