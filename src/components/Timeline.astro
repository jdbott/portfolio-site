---
import type { TimelineItem } from '../data/areas';

interface Props {
  items: TimelineItem[];
  heading?: string;
}

const { items, heading = 'Timeline' } = Astro.props;
---

<section class="timeline">
  <div class="timeline__inner">
    <h2 class="timeline__heading scroll-reveal">{heading}</h2>
    <ol class="timeline__list">
      {items.map((item) => (
        <li class="timeline__item scroll-reveal">
          <span class="timeline__date">{item.date}</span>
          <span class="timeline__marker" aria-hidden="true"></span>
          <div class="timeline__body">
            <h3 class="timeline__title">{item.title}</h3>
            {item.meta && <p class="timeline__meta">{item.meta}</p>}
            <p class="timeline__description">{item.description}</p>
            {item.courses && item.courses.length > 0 && (
              <ul class="timeline__courses" aria-label={`${item.date} courses`}>
                {item.courses.map((course) => <li>{course}</li>)}
              </ul>
            )}
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .timeline {
    padding: var(--space-2xl) var(--space-lg);
  }

  .timeline__inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .timeline__heading {
    font-weight: 700;
    font-size: clamp(1.75rem, 5vw, var(--fs-2xl));
    line-height: var(--lh-tight);
    margin-bottom: var(--space-xl);
  }

  .timeline__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--color-border);
  }

  .timeline__item {
    position: relative;
    display: grid;
    grid-template-columns: 9rem minmax(0, 1fr);
    gap: var(--space-lg);
    padding: 0 0 var(--space-xl) var(--space-lg);
  }

  .timeline__item:last-child {
    padding-bottom: 0;
  }

  .timeline__marker {
    position: absolute;
    left: -1px;
    top: 0.4rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-accent-strong);
    transform: translateX(-50%);
    box-shadow: 0 0 0 4px var(--color-bg);
  }

  .timeline__date {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-sm);
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .timeline__title {
    font-weight: 700;
    font-size: var(--fs-md);
  }

  .timeline__meta {
    margin-top: var(--space-3xs);
    color: var(--color-gold);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .timeline__description {
    margin-top: var(--space-sm);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .timeline__courses {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    list-style: none;
    margin: var(--space-md) 0 0;
    padding: 0;
  }

  .timeline__courses li {
    padding: var(--space-3xs) var(--space-xs);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg-raised);
    color: var(--color-text-muted);
    font-size: var(--fs-xs);
  }

  @media (max-width: 640px) {
    .timeline__item {
      grid-template-columns: 1fr;
      gap: var(--space-2xs);
    }
  }
</style>
