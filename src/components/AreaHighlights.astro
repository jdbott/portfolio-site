---
import { Image } from 'astro:assets';
import { sortedAreas } from '../data/areas';

import rickcohenImg from '../assets/rickcohen.jpeg';
import campinventionImg from '../assets/campinvention.jpeg';
import roboticsImg from '../assets/robotics.jpeg';
import photographyImg from '../assets/photography.jpeg';
import bonsaiImg from '../assets/bonsai.JPG';
import fitnessImg from '../assets/fitness.jpeg';
import proclaimationImg from '../assets/proclaimation.jpeg';
import autosimImg from '../assets/autosim.png';

// height={680} = 2× the 340px max display height, so images are sharp on
// retina screens without being wastefully large.
const tiles = [
  { src: rickcohenImg,    alt: 'Rick Cohen examining our robot up close at competition', href: '/robotics/' },
  { src: campinventionImg, alt: 'Volunteering at Camp Invention', href: '/service/' },
  { src: roboticsImg,     alt: 'Robotics', href: '/robotics/' },
  { src: photographyImg,  alt: 'Photography', href: '/pursuits/' },
  { src: bonsaiImg,       alt: 'Bonsai', href: '/pursuits/' },
  { src: fitnessImg,      alt: 'Fitness', href: '/pursuits/' },
  { src: proclaimationImg, alt: 'Proclamation', href: '/service/' },
  { src: autosimImg,      alt: 'AutoSim autonomous simulation tool', href: '/projects/' },
];
---

<section class="highlights">
  <div class="highlights__band">
    <div class="highlights__marquee" aria-hidden="true">
      <div class="highlights__marquee-track">
        {[...tiles, ...tiles].map((tile, i) => (
          <a class="highlights__marquee-item" href={tile.href} aria-hidden={i >= tiles.length ? 'true' : undefined} tabindex={i >= tiles.length ? -1 : undefined}>
            <Image
              class="highlights__marquee-img"
              src={tile.src}
              alt={tile.alt}
              height={680}
              widths={[340, 680, 1020, 1500]}
              sizes="(max-width: 640px) 40vw, 30vw"
            />
          </a>
        ))}
      </div>
    </div>

    <div class="highlights__band-overlay">
      <p class="highlights__eyebrow scroll-reveal">Explore</p>
      <h2 class="highlights__heading scroll-reveal">Everything else, by area.</h2>
    </div>
  </div>

  <div class="highlights__inner">
    <div class="highlights__list">
      {sortedAreas.map((area) => (
        <a href={`/${area.slug}/`} class="highlight scroll-reveal">
          <span class="highlight__index">{String(area.order).padStart(2, '0')}</span>
          <span class="highlight__body">
            <span class="highlight__title">{area.title}</span>
            <span class="highlight__summary">{area.summary}</span>
          </span>
          <span class="highlight__cta" aria-hidden="true">&rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .highlights {
    padding: var(--space-xl) var(--space-lg) var(--space-2xl);
  }

  .highlights__band {
    position: relative;
    max-width: 1400px;
    margin: 0 auto var(--space-xl);
    height: clamp(220px, 32vw, 340px);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .highlights__marquee {
    position: absolute;
    inset: 0;
  }

  .highlights__marquee-track {
    display: flex;
    align-items: stretch;
    width: max-content;
    height: 100%;
    gap: var(--space-sm);
    padding: var(--space-sm);
    animation: highlights-marquee 80s linear infinite;
    will-change: transform;
  }

  .highlights__marquee-item {
    flex: 0 0 auto;
    height: 100%;
    border-radius: var(--radius-md);
    overflow: hidden;
    display: block;
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-out-expo);
  }

  .highlights__marquee-item:hover {
    opacity: 0.8;
  }

  .highlights__marquee-img {
    height: 100%;
    width: auto;
    display: block;
    border-radius: inherit;
  }

  @keyframes highlights-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .highlights__band-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-xl) var(--space-lg);
    background: linear-gradient(
      90deg,
      rgba(7, 7, 10, 0.92) 0%,
      rgba(7, 7, 10, 0.60) 35%,
      transparent 65%
    );
    pointer-events: none;
  }

  .highlights__inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .highlights__eyebrow {
    font-size: var(--fs-xs);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-xs);
  }

  .highlights__heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 5vw, var(--fs-2xl));
    line-height: var(--lh-tight);
  }

  .highlights__list {
    display: flex;
    flex-direction: column;
  }

  .highlight {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .highlights__list .highlight:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .highlight__index {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-sm);
    color: var(--color-text-faint);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .highlight__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .highlight__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.25rem, 3.5vw, var(--fs-xl));
  }

  .highlight__summary {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .highlight__cta {
    font-size: var(--fs-lg);
    color: var(--color-text-faint);
    transform: translateX(0);
    transition:
      color var(--duration-fast) var(--ease-out-expo),
      transform var(--duration-fast) var(--ease-out-expo);
  }

  .highlight:hover { color: var(--color-accent-strong); }
  .highlight:hover .highlight__index { color: var(--color-accent-strong); }
  .highlight:hover .highlight__cta {
    color: var(--color-accent-strong);
    transform: translateX(6px);
  }

  @media (prefers-reduced-motion: reduce) {
    .highlights__marquee-track { animation: none; }
  }

  @media (max-width: 640px) {
    .highlight { grid-template-columns: 2.5rem 1fr; }
    .highlight__cta { display: none; }
    .highlights__band-overlay {
      background: linear-gradient(
        180deg,
        rgba(7, 7, 10, 0.85) 0%,
        rgba(7, 7, 10, 0.50) 100%
      );
    }
  }
</style>
