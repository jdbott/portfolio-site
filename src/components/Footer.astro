---
import Monogram from './Monogram.astro';
import { sortedAreas } from '../data/areas';

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <Monogram size={28} />
      <p class="footer__name">Jason Bottino</p>
    </div>

    <nav class="footer__links" aria-label="Footer">
      <a href="/">Home</a>
      {sortedAreas.map((area) => (
        <a href={`/${area.slug}/`}>{area.navLabel}</a>
      ))}
    </nav>

    <div class="footer__contact">
      <a href="mailto:jason.bottino@asdnh.org" class="footer__email">jason.bottino@asdnh.org</a>
      <div class="footer__socials">
        <a href="https://github.com/jdbott" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>
  </div>

  <p class="footer__legal">&copy; {currentYear} Jason Bottino. All rights reserved.</p>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-md) var(--space-lg);
  }

  .footer__inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md) var(--space-xl);
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
  }

  .footer__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-sm);
    color: var(--color-text);
  }

  .footer__links {
    display: grid;
    grid-template-columns: repeat(3, auto);
    grid-auto-flow: row;
    row-gap: var(--space-2xs);
    column-gap: var(--space-md);
  }

  .footer__contact {
    display: grid;
    grid-template-rows: repeat(2, auto);
    row-gap: var(--space-2xs);
    text-align: right;
  }

  .footer__links a,
  .footer__email,
  .footer__socials a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--fs-xs);
    line-height: 1.5;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .footer__links a:hover,
  .footer__email:hover,
  .footer__socials a:hover {
    color: var(--color-accent-strong);
  }

  .footer__socials {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-md);
  }

  .footer__legal {
    max-width: var(--content-max-width);
    margin: var(--space-sm) auto 0;
    font-size: var(--fs-2xs);
    color: var(--color-text-faint);
  }

  @media (max-width: 560px) {
    .footer__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer__contact {
      text-align: left;
    }

    .footer__socials {
      justify-content: flex-start;
    }
  }
</style>
