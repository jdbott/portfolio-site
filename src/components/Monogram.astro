---
// Elegant "JB" monogram. Adjust the two letters, weight, or accent
// dot color/position here — used in the nav and can be reused for
// the favicon/social previews later.
interface Props {
  size?: number;
  class?: string;
}

const { size = 36, class: className = '' } = Astro.props;
---

<svg
  class={`monogram ${className}`}
  width={size}
  height={size}
  viewBox="0 0 48 48"
  role="img"
  aria-label="Jason Bottino — JB monogram"
>
  <text
    x="24"
    y="33"
    text-anchor="middle"
    class="monogram__text"
  >JB</text>
  <circle class="monogram__dot" cx="40" cy="10" r="3" />
</svg>

<style>
  .monogram {
    display: block;
    flex-shrink: 0;
  }

  .monogram__text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 22px;
    letter-spacing: -0.04em;
    fill: var(--color-text);
  }

  .monogram__dot {
    fill: var(--color-accent);
  }
</style>
