---
import type { Stat } from '../data/areas';

interface Props {
  stats?: Stat[];
}

const {
  stats = [
    { value: '4+', label: 'Years building in FTC' },
    { value: '12+', label: 'Competitions & events' },
    { value: '150+', label: 'Community service hours' },
    { value: '6', label: 'Awards & recognitions' },
  ],
} = Astro.props;
---

<section class="stats">
  <div class="stats__inner">
    {stats.map((stat) => (
      <div class="stats__item scroll-reveal">
        <p class="stats__value">{stat.value}</p>
        <p class="stats__label">{stat.label}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .stats {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-2xl) var(--space-lg);
  }

  .stats__inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .stats__value {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 6vw, var(--fs-2xl));
    line-height: var(--lh-tight);
    color: var(--color-text);
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-accent-strong) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .stats__label {
    margin-top: var(--space-2xs);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    max-width: 18ch;
  }

  @media (max-width: 760px) {
    .stats__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-xl) var(--space-lg);
    }
  }
</style>
