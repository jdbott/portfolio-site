---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  navAlwaysVisible?: boolean;
}

const {
  title = 'Jason Bottino',
  description = 'Student, roboticist, and builder — portfolio in progress.',
  navAlwaysVisible = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL('/social-preview.jpg', Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg?v=4" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico?v=4" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico?v=4" />
    <link rel="apple-touch-icon" href="/favicon.ico?v=4" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>

    <!-- Open Graph (Facebook, LinkedIn, Discord, Slack, iMessage, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Jason Bottino" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter/X falls back to the Open Graph tags above when its own are
         absent, so only the card type needs to be set explicitly. -->
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <Nav alwaysVisible={navAlwaysVisible} />
    <slot />
    <Footer />
  </body>
</html>
