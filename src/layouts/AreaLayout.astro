---
import BaseLayout from './BaseLayout.astro';
import StatsBand from '../components/StatsBand.astro';
import Timeline from '../components/Timeline.astro';
import ContentCards from '../components/ContentCards.astro';
import Gallery from '../components/Gallery.astro';
import Quote from '../components/Quote.astro';
import PursuitsShowcase from '../components/PursuitsShowcase.astro';
import ServiceShowcase from '../components/ServiceShowcase.astro';
import RoboticsShowcase from '../components/RoboticsShowcase.astro';
import { Image } from 'astro:assets';
import aboutImg from '../assets/jasonaboutme.jpg';
import mainRoboticsImg from '../assets/newmainrobotics.JPG';
import blenderExampleVideo from '../assets/blenderexample-web.mp4?url';
import type { Area } from '../data/areas';

interface Props {
  area: Area;
}

const { area } = Astro.props;
const showAreaHero = area.slug !== 'projects' && area.slug !== 'about';
---

<BaseLayout title={`${area.title} — Jason Bottino`} description={area.summary} navAlwaysVisible>
  {showAreaHero && (
    <header class:list={['area-hero', { 'area-hero--compact': area.slug === 'academics' || area.slug === 'service' || area.slug === 'robotics' }]}>
      {area.slug === 'robotics' && (
        <div class="area-hero__media" aria-hidden="true">
          <Image
            class="area-hero__media-image"
            src={mainRoboticsImg}
            alt=""
            widths={[600, 900, 1200, 1600]}
            sizes="(max-width: 900px) 100vw, 50vw"
            quality={88}
            loading="eager"
          />
        </div>
      )}

      <div class="area-hero__inner">
        <p class="area-hero__eyebrow scroll-reveal">
          {String(area.order).padStart(2, '0')} — {area.eyebrow ?? 'Area'}
        </p>
        <h1 class="area-hero__title scroll-reveal">{area.title}</h1>
        <p class="area-hero__summary scroll-reveal">{area.summary}</p>
      </div>

      {(area.slug === 'academics' || area.slug === 'pursuits' || area.slug === 'service' || area.slug === 'robotics') && (
        <div class="area-hero__scroll-cue scroll-reveal" aria-hidden="true">
          <span class="area-hero__scroll-line"></span>
          <span>Scroll</span>
        </div>
      )}
    </header>
  )}

  {area.slug === 'projects' ? (
    <section class="projects-placeholder" aria-label="Projects coming soon">
      <div class="projects-placeholder__inner scroll-reveal">
        <p class="projects-placeholder__kicker">Under construction</p>
        <h2 class="projects-placeholder__heading">Project details forthcoming.</h2>
        <p class="projects-placeholder__text">
          Check back soon to see what I am building! This section will become an archive for technical projects, experiments, and longer-term builds.
        </p>
      </div>
    </section>
  ) : area.slug === 'about' ? (
    <section class="about-placeholder" aria-label="About Me">
      <div class="about-placeholder__inner">
        <div class="about-placeholder__copy scroll-reveal">
          <p class="about-placeholder__kicker">About Me</p>
          <h2 class="about-placeholder__heading">Ambition, curiosity, and passing it along.</h2>
          <p class="about-placeholder__text">
            I’ve always been ambitious, but never because someone handed me directions to follow. In fact, as a kid, I was the one who threw away the directions...immediately. A robotics kit meant to build a cart that drove in a straight line became a 3-axis robotic arm after a few late nights, and marble runs spiraled into crazy experiments including a breath-powered pneumatic loop-de-loop that ended with me swallowing the marble. My family still jokes about me...passing it along. The phrase stuck, though, because it fits into something I actually believe: I was lucky to grow up with the tools, space, and encouragement to chase whatever caught my curiosity, and I’m sharply aware not everyone gets that - so I try to pass it along for real, through service and advocacy that gives those same opportunities to other people. Most of what I know I taught myself: take something in, take it apart, figure out how it works. I’m intense and competitive about what I care about, especially STEM, but I’ve never let that stand between me and people. More than anything, I want to prove what sustained effort does: that the right mindset and a few core values, repeated seriously over years, grow into something far bigger than where they started.
          </p>
        </div>

        <div class="about-placeholder__portrait scroll-reveal" aria-label="Portrait placeholder">
          <div class="about-placeholder__portrait-frame">
            <Image
              class="about-placeholder__image"
              src={aboutImg}
              alt="Portrait of Jason Bottino"
              widths={[420, 640, 820, 1100, 1400]}
              sizes="(max-width: 860px) calc(100vw - 5rem), 34vw"
              quality={90}
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>
  ) : area.slug === 'service' ? (
    <>
      <StatsBand stats={area.stats} compact spacedTail />
      <ServiceShowcase />
    </>
  ) : area.slug === 'robotics' ? (
    <>
      <StatsBand stats={area.stats} compact spacedTail />
      {area.quote && <Quote quote={area.quote} compact />}
      <RoboticsShowcase galleryCount={area.galleryCount} />
    </>
  ) : area.pursuits ? (
    <PursuitsShowcase pursuits={area.pursuits} />
  ) : (
    <>
      <StatsBand stats={area.stats} compact={area.slug === 'academics'} />

      {area.timeline.length > 0 && <Timeline items={area.timeline} />}

      {area.feature && (
        <section class:list={['area-feature', { 'area-feature--compact': area.slug === 'academics' }]}>
          <div class="area-feature__inner scroll-reveal">
            <div class="area-feature__copy">
              <h2 class="area-feature__heading">{area.feature.heading}</h2>
              <p class="area-feature__text">{area.feature.text}</p>
            </div>

            {area.slug === 'academics' && (
              <figure class="area-feature__media">
                <video
                  class="area-feature__video"
                  data-academic-video
                  src={blenderExampleVideo}
                  autoplay
                  loop
                  muted
                  defaultMuted
                  playsinline
                  webkit-playsinline="true"
                  preload="auto"
                  aria-label="Blender animation example"
                />
                <button class="area-feature__video-prompt" type="button" data-academic-video-prompt>
                  Click for the animation
                </button>
                <figcaption class="area-feature__caption">
                  Blender animation learned independently, inspired by my physics class.
                </figcaption>
              </figure>
            )}
          </div>
        </section>
      )}

      <ContentCards heading={area.cardsHeading} cards={area.cards} compact={area.slug === 'academics'} />

      {area.galleryCount > 0 && <Gallery count={area.galleryCount} compact={area.slug === 'academics'} />}

      {area.quote && <Quote quote={area.quote} />}
    </>
  )}
</BaseLayout>

<script>
  const reveals = document.querySelectorAll('.scroll-reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.2, rootMargin: '0px 0px -10% 0px' }
  );

  reveals.forEach((el, i) => {
    (el as HTMLElement).style.transitionDelay = `${(i % 4) * 90}ms`;
    observer.observe(el);
  });

  const academicVideos = Array.from(document.querySelectorAll<HTMLVideoElement>('[data-academic-video]'));
  const warmAcademicVideos = new WeakSet<HTMLVideoElement>();

  const setAcademicVideoPrompt = (video: HTMLVideoElement, visible: boolean) => {
    const prompt = video.parentElement?.querySelector<HTMLElement>('[data-academic-video-prompt]');
    prompt?.classList.toggle('is-visible', visible);
  };

  const playAcademicVideo = (video: HTMLVideoElement, attempt = 0) => {
    video.muted = true;
    video.defaultMuted = true;
    video.playsInline = true;
    video.autoplay = true;
    video.loop = true;
    video.setAttribute('muted', '');
    video.setAttribute('playsinline', '');
    video.setAttribute('webkit-playsinline', 'true');
    video.setAttribute('preload', 'auto');

    if (video.networkState === HTMLMediaElement.NETWORK_EMPTY) {
      video.load();
    }

    const playPromise = video.play();
    if (playPromise && typeof playPromise.catch === 'function') {
      playPromise.then(() => {
        setAcademicVideoPrompt(video, false);
      }).catch(() => {
        if (attempt < 8) {
          window.setTimeout(() => playAcademicVideo(video, attempt + 1), 180 + attempt * 120);
        } else {
          setAcademicVideoPrompt(video, true);
        }
      });
    }
  };

  const warmAndPlayAcademicVideo = (video: HTMLVideoElement) => {
    if (!warmAcademicVideos.has(video)) {
      warmAcademicVideos.add(video);
      video.load();
    }
    playAcademicVideo(video);
  };

  academicVideos.forEach((video) => {
    video.addEventListener('loadedmetadata', () => playAcademicVideo(video));
    video.addEventListener('canplay', () => playAcademicVideo(video));
    video.addEventListener('playing', () => {
      video.dataset.playing = 'true';
      setAcademicVideoPrompt(video, false);
    });
    video.addEventListener('pause', () => {
      if (!document.hidden) setAcademicVideoPrompt(video, true);
    });
    video.closest('.scroll-reveal')?.addEventListener('transitionend', () => {
      playAcademicVideo(video);
    });
    video.parentElement?.querySelector<HTMLElement>('[data-academic-video-prompt]')?.addEventListener('click', () => {
      playAcademicVideo(video, 8);
    });
    warmAndPlayAcademicVideo(video);
  });

  if ('IntersectionObserver' in window) {
    const academicVideoObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            warmAndPlayAcademicVideo(entry.target as HTMLVideoElement);
          }
        }
      },
      { threshold: 0.01, rootMargin: '600px 0px' }
    );
    academicVideos.forEach((video) => academicVideoObserver.observe(video));
  } else {
    academicVideos.forEach(warmAndPlayAcademicVideo);
  }

  const retryAcademicVideos = () => {
    academicVideos.forEach((video) => {
      if (video.paused || video.readyState < HTMLMediaElement.HAVE_FUTURE_DATA) {
        warmAndPlayAcademicVideo(video);
      }
    });
  };

  window.addEventListener('pageshow', retryAcademicVideos);
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) retryAcademicVideos();
  });
  window.addEventListener('scroll', retryAcademicVideos, { passive: true });
  window.addEventListener('pointerdown', retryAcademicVideos, { passive: true });
  window.addEventListener('touchstart', retryAcademicVideos, { passive: true });
  [250, 800, 1600, 3200].forEach((delay) => {
    window.setTimeout(retryAcademicVideos, delay);
  });

  window.setTimeout(() => {
    academicVideos.forEach((video) => {
      if (video.paused) setAcademicVideoPrompt(video, true);
    });
  }, 1800);
</script>

<style>
  .area-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding: var(--space-3xl) var(--space-lg) var(--space-xl);
    overflow: hidden;
  }

  .area-hero--compact {
    min-height: 48vh;
    padding-top: clamp(6rem, 11vh, 7rem);
    padding-bottom: var(--space-lg);
  }

  .area-hero__media {
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    /* Confined to the blank space to the right of the title/summary text,
       not the full hero width, so it never competes with the copy. */
    width: clamp(380px, 46vw, 760px);
    z-index: 0;
    overflow: hidden;
  }

  .area-hero__media::after {
    content: '';
    position: absolute;
    inset: 0;
    /* Soft fade into the page background on the inner edge and toward the
       bottom, so the photo dissolves before reaching the stats band
       instead of ending in a hard rectangle. */
    background:
      linear-gradient(to right, var(--color-bg) 0%, transparent 16%),
      linear-gradient(to bottom, transparent 42%, var(--color-bg) 94%);
  }

  .area-hero__media-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Centered on the cluster of people examining the robot. */
    object-position: 42% 32%;
    transform: scale(1.18);
  }

  .area-hero__inner {
    position: relative;
    z-index: 1;
    max-width: var(--content-max-width);
    width: 100%;
    margin: 0 auto;
  }

  .area-hero__eyebrow {
    font-size: var(--fs-xs);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-accent-strong);
    margin-bottom: var(--space-md);
  }

  .area-hero__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.5rem, 9vw, var(--fs-3xl));
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .area-hero__summary {
    font-size: var(--fs-md);
    color: var(--color-text-muted);
    max-width: 50ch;
  }

  .area-hero__scroll-cue {
    position: absolute;
    right: var(--space-lg);
    bottom: var(--space-lg);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-text-faint);
    font-size: var(--fs-2xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .area-hero__scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, var(--color-text-faint), transparent);
    animation: area-scroll-pulse 2.4s ease-in-out infinite;
  }

  @keyframes area-scroll-pulse {
    0%, 100% { transform: scaleY(1); opacity: 0.4; }
    50% { transform: scaleY(1.4); opacity: 1; }
  }

  .area-feature {
    padding: var(--space-xl) var(--space-lg) var(--space-2xl);
  }

  .area-feature--compact {
    padding-top: var(--space-lg);
    padding-bottom: var(--space-lg);
  }

  @media (max-width: 700px) {
    .area-hero__scroll-cue {
      right: var(--space-md);
      bottom: var(--space-md);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .area-hero__scroll-line {
      animation: none;
    }
  }

  .area-feature__inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-raised);
  }

  .area-feature--compact .area-feature__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(280px, 0.95fr);
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    max-width: 1040px;
  }

  .area-feature__copy {
    min-width: 0;
  }

  .area-feature__heading {
    font-size: clamp(1.5rem, 4vw, var(--fs-xl));
    margin-bottom: var(--space-md);
  }

  .area-feature__text {
    max-width: 70ch;
    color: var(--color-text-muted);
    font-size: var(--fs-md);
  }

  .area-feature--compact .area-feature__text {
    max-width: 48ch;
  }

  .area-feature__media {
    position: relative;
    margin: 0;
    min-width: 0;
  }

  .area-feature__video {
    display: block;
    width: 100%;
    max-height: min(62vh, 620px);
    aspect-ratio: 9 / 16;
    object-fit: contain;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-overlay);
  }

  .area-feature__caption {
    margin-top: var(--space-xs);
    color: var(--color-text-muted);
    font-size: var(--fs-xs);
    line-height: 1.5;
  }

  .area-feature__video-prompt {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 2;
    transform: translate(-50%, -50%);
    display: none;
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    background: rgba(10, 10, 14, 0.72);
    color: var(--color-text);
    font: inherit;
    font-size: var(--fs-xs);
    font-weight: 600;
    cursor: pointer;
    backdrop-filter: blur(12px);
  }

  .area-feature__video-prompt.is-visible {
    display: inline-flex;
  }

  @media (max-width: 820px) {
    .area-feature--compact .area-feature__inner {
      grid-template-columns: 1fr;
      max-width: 680px;
    }

    .area-feature--compact .area-feature__text {
      max-width: 70ch;
    }
  }

  .projects-placeholder,
  .about-placeholder {
    padding: clamp(7rem, 16vh, 10rem) var(--space-lg) var(--space-3xl);
  }

  .projects-placeholder__inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 5rem);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at 12% 20%, rgba(226, 51, 77, 0.18), transparent 34%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.015));
    overflow: hidden;
    position: relative;
  }

  .projects-placeholder__inner::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent, rgba(255, 255, 255, 0.08), transparent);
    transform: translateX(-120%);
    animation: projects-sheen 5s ease-in-out infinite;
    pointer-events: none;
  }

  .projects-placeholder__kicker,
  .about-placeholder__kicker {
    font-size: var(--fs-xs);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-accent-strong);
    margin-bottom: var(--space-sm);
  }

  .projects-placeholder__heading,
  .about-placeholder__heading {
    font-size: clamp(2rem, 6vw, var(--fs-2xl));
    margin-bottom: var(--space-md);
  }

  .projects-placeholder__text,
  .about-placeholder__text {
    max-width: 68ch;
    color: var(--color-text-muted);
    font-size: var(--fs-md);
  }

  .about-placeholder__inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.72fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  .about-placeholder__copy {
    min-width: 0;
  }

  .about-placeholder__note {
    margin-top: var(--space-md);
    max-width: 66ch;
    color: var(--color-text-faint);
    font-size: var(--fs-xs);
  }

  .about-placeholder__note code {
    color: var(--color-text-muted);
    font-family: inherit;
  }

  .about-placeholder__portrait {
    min-width: 0;
  }

  .about-placeholder__portrait-frame {
    aspect-ratio: 4 / 5;
    min-height: 420px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-raised);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xs);
    color: var(--color-text-muted);
    text-align: center;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.22);
  }

  .about-placeholder__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
  }

  @keyframes projects-sheen {
    0%, 55% { transform: translateX(-120%); }
    80%, 100% { transform: translateX(120%); }
  }

  @media (max-width: 860px) {
    .about-placeholder__inner {
      grid-template-columns: 1fr;
    }

    .about-placeholder__portrait-frame {
      min-height: 320px;
    }
  }

  @media (max-width: 900px) {
    .area-hero__media {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .projects-placeholder__inner::after {
      animation: none;
      transform: none;
      opacity: 0;
    }
  }
</style>
